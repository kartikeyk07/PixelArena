

    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'kongekartikey007@gmail.com';
    }
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read/write their own document
      allow read, write: if request.auth.uid == userId;
      // Admins can read all user documents
      allow read: if isAdmin();
    }
    
    // Bookings collection
    match /bookings/{bookingId} {
      // Authenticated users can read all bookings (to check availability)
      allow read: if isAuthenticated();
      // Users can create bookings (with required fields)
      allow create: if isAuthenticated() && 
                        request.auth.uid == request.resource.data.userId &&
                        request.resource.data.gameId != null &&
                        request.resource.data.slot != null &&
                        request.resource.data.date != null &&
                        request.resource.data.zoneId != null;
      // Users can update/delete their own bookings, admins can do anything
      allow update, delete: if isAuthenticated() && 
                               (request.auth.uid == resource.data.userId || isAdmin());
    }
    
    // Zones collection (public read, admin write)
    match /zones/{zoneId} {
      // Anyone can read zones for browsing
      allow read: if true;
      // Only admins can create/update/delete zones
      allow create, update, delete: if isAdmin() &&
                                       request.resource.data.name != null &&
                                       request.resource.data.location != null;
      
      // Sub-collection: games within zones
      match /games/{gameId} {
        allow read: if true;
        allow create, update, delete: if isAdmin() &&
                                         request.resource.data.name != null &&
                                         request.resource.data.pricePerHour != null;
      }
      
      // Sub-collection: cafe items within zones
      match /cafe/{itemId} {
        allow read: if true;
        allow create, update, delete: if isAdmin() &&
                                         request.resource.data.name != null &&
                                         request.resource.data.price != null;
      }
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
